---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import OfferingCards from '../components/OfferingCards.astro';
import Testimonials from '../components/Testimonials.astro';
import Modal from '../components/Modal.astro';
import Footer from '../components/Footer.astro';
---

<Layout>

  <!-- Fixed Navbar -->
  <Navbar />

  <!-- Hero + Video sections -->
  <Hero />

  <!-- ── Page Sections ── -->

  <!-- 3. About -->
  <section class="page-section about-section reveal-on-scroll" id="about">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <h2 data-typewriter="What makes QRH different?" data-typewriter-delay="200">What makes QRH different?</h2>
          <p class="reveal-on-scroll" data-reveal-delay="2">We guide you beyond what you thought was possible &#8212; whether through personal sessions or practitioner training.</p>
          <p class="reveal-on-scroll" data-reveal-delay="3">Healing here isn&#39;t about fixing what&#39;s broken; it&#39;s about discovering what&#39;s already extraordinary.</p>
        </div>
        <div class="about-image reveal-on-scroll" data-reveal-delay="2" role="img" aria-label="QRH healing environment"></div>
      </div>
    </div>
  </section>

  <!-- 4. Training Journey — scroll-in card stack (one card per scroll step) -->
  <!--
    STRUCTURE:
    - .training-scroll-outer = tall outer (400vh) that gives scroll room
    - .training-sticky-viewport = position:sticky; height:100vh — pins to screen
    - .training-header-sticky = header inside sticky viewport
    - .training-cards-stage = relative container for all cards
    - .training-card = absolute positioned, starts translateY(100%) — enters one by one
    GSAP ScrollTrigger scrubs each card from translateY(100%) → 0
    at evenly spaced scroll positions. z-index layering: later cards on top.
  -->
  <div id="training-scroll-outer" class="training-scroll-outer">
    <div class="training-sticky-viewport">

      <!-- Header stays visible while cards scroll in -->
      <div class="training-header">
        <p class="training-label">Training</p>
        <h2 class="training-heading">
          <span class="dim">The</span>
          <span>Training Journey</span>
        </h2>
        <p class="training-subtext">Our 6-month program combines mentorship, immersive practice, and personal growth. An invitation to fully embody the work and confidently guide others.</p>
      </div>

      <!-- Card stage: all cards absolutely stacked, enter from bottom -->
      <div class="training-cards-stage" id="training-cards-stage">

        <div class="training-card" data-card-index="0" style="--accent: #d4af37; z-index: 1;">
          <div class="training-inner">
            <div class="training-content">
              <div class="training-meta">
                <h3 class="training-title"><span class="training-num">01</span>Mentorship</h3>
                <span class="training-badge">Foundation</span>
              </div>
              <p class="training-desc">Weekly one-on-one and group sessions with experienced practitioners. Personal guidance through the depths of your learning journey.</p>
            </div>
            <div class="training-milestone">
              <div class="milestone-label">Month</div>
              <div class="milestone-val">1–2</div>
              <div class="milestone-tag">Core</div>
            </div>
          </div>
        </div>

        <div class="training-card" data-card-index="1" style="--accent: #20b2aa; z-index: 2;">
          <div class="training-inner">
            <div class="training-content">
              <div class="training-meta">
                <h3 class="training-title"><span class="training-num">02</span>Practice</h3>
                <span class="training-badge">Applied</span>
              </div>
              <p class="training-desc">Hands-on practice and guided exploration in real-world settings. Build genuine mastery through applied technique and feedback.</p>
            </div>
            <div class="training-milestone">
              <div class="milestone-label">Month</div>
              <div class="milestone-val">3–4</div>
              <div class="milestone-tag">Mastery</div>
            </div>
          </div>
        </div>

        <div class="training-card" data-card-index="2" style="--accent: #d4af37; z-index: 3;">
          <div class="training-inner">
            <div class="training-content">
              <div class="training-meta">
                <h3 class="training-title"><span class="training-num">03</span>Support</h3>
                <span class="training-badge">Growth</span>
              </div>
              <p class="training-desc">Marketing and client-building support to launch your practice. You won't walk into your new career alone — we've got you covered.</p>
            </div>
            <div class="training-milestone">
              <div class="milestone-label">Month</div>
              <div class="milestone-val">5</div>
              <div class="milestone-tag">Launch</div>
            </div>
          </div>
        </div>

        <div class="training-card" data-card-index="3" style="--accent: #20b2aa; z-index: 4;">
          <div class="training-inner">
            <div class="training-content">
              <div class="training-meta">
                <h3 class="training-title"><span class="training-num">04</span>Certification</h3>
                <span class="training-badge">Completion</span>
              </div>
              <p class="training-desc">Certificate of completion acknowledging your training and expertise. A credential that opens doors and confirms your readiness to guide others.</p>
            </div>
            <div class="training-milestone">
              <div class="milestone-label">Month</div>
              <div class="milestone-val">6</div>
              <div class="milestone-tag">Certified</div>
            </div>
          </div>
        </div>

      </div><!-- /training-cards-stage -->
    </div><!-- /training-sticky-viewport -->
  </div><!-- /training-scroll-outer -->

  <!-- 5. Therapy / Personal Healing -->
  <section class="page-section therapy-section reveal-on-scroll" id="therapy-section">
    <div class="container">
      <div class="therapy-content">
        <div class="therapy-text">
          <h2 data-typewriter="Personal Healing Sessions" data-typewriter-delay="200">Personal Healing Sessions</h2>
          <p class="reveal-on-scroll" data-reveal-delay="2">Individual sessions that take you to the root of your psyche and beyond. These are not about temporary relief &#8212; they&#39;re about transformation.</p>
          <p class="reveal-on-scroll" data-reveal-delay="3">Experience a unique approach to healing that awakens what&#39;s already extraordinary within you.</p>
        </div>
        <div class="therapy-images reveal-on-scroll" data-reveal-delay="2">
          <div class="workshop-image" role="img" aria-label="Workshop environment"></div>
          <div class="therapy-image" role="img" aria-label="Therapy session environment"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Testimonials -->
  <section class="page-section testimonials-section reveal-on-scroll">
    <div class="testimonial-container">
      <h3 data-typewriter="What Our Community Says" data-typewriter-delay="200">What Our Community Says</h3>
      <Testimonials />
    </div>
  </section>

  <!-- 7. Your Pathways -->
  <section class="page-section offerings-section reveal-on-scroll" id="offerings">
    <div class="container">
      <h2 data-typewriter="Your Pathways" data-typewriter-delay="200">Your Pathways</h2>
      <p class="section-subtext reveal-on-scroll" data-reveal-delay="2">You&#39;ve seen the work. Now choose your path &#8212; a personal healing session or the full practitioner training journey.</p>
      <OfferingCards />
    </div>
  </section>

  <!-- Footer -->
  <Footer />

  <!-- Global booking modal -->
  <Modal />

</Layout>

<style>
  /* ── Base resets for this page ── */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    font-family: 'Lato', sans-serif;
    line-height: 1.6;
    color: #2c3e50;
    overflow-x: clip;
    width: 100%;
  }
  body { background: #ffffff; }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Page sections ── */
  .page-section {
    position: relative;
    width: 100%;
    background: #ffffff;
    padding: 80px 0 60px;
  }

  /* ── Shared heading + subtext ── */
  .page-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: #0f4c75;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 1rem;
    min-height: 1.2em; /* prevent layout shift during typewriter */
  }

  .section-subtext {
    font-size: 1.15rem;
    color: #5a6c7d;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 700px;
  }

  /* ── About ── */
  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-text p {
    font-size: 1.15rem;
    color: #2c3e50;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .about-image {
    width: 100%;
    height: clamp(220px, 38vh, 420px);
    background-image: url('/images/about-image.webp');
    background-size: cover;
    background-position: center;
    border-radius: 20px;
  }

  /* ── Offerings ── */
  .offerings-section h2 { text-align: center; }
  .offerings-section .section-subtext {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Training Journey: scroll-in card stack ── */

  /*
   * Outer scroll container — 500vh gives plenty of scroll room for 4 cards.
   * Each card enters at 25% increments of this container's scroll range.
   */
  .training-scroll-outer {
    position: relative;
    height: 500vh;
    background: #ffffff;
  }

  /*
   * Sticky viewport — pins to top of screen for the full scroll of outer.
   * overflow:hidden clips cards entering from below.
   * Uses 100dvh (dynamic viewport height) so it shrinks when the mobile URL
   * bar appears and expands when it hides — no padding hack needed.
   * Falls back to 100svh (small viewport) then 100vh for older browsers.
   */
  .training-sticky-viewport {
    position: sticky;
    top: 0;
    height: 100vh; /* base fallback */
    height: 100svh; /* small viewport: locks to URL-bar-visible height */
    height: 100dvh; /* dynamic: adjusts as URL bar shows/hides */
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Header at top of sticky viewport — light theme */
  .training-header {
    flex-shrink: 0;
    padding: 3.5rem 4rem 1.5rem;
    background: #ffffff;
    position: relative;
    z-index: 10;
  }

  .training-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .training-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 1;
    color: #0f4c75;
    margin-bottom: 1rem;
    min-height: 1.2em;
  }

  .training-heading span { display: block; }
  .training-heading .dim { color: rgba(15,76,117,0.3); }

  .training-subtext {
    font-size: 1rem;
    line-height: 1.65;
    color: #5a6c7d;
    max-width: 600px;
    margin-top: 0.75rem;
  }

  /*
   * Cards stage — fills remaining sticky viewport height.
   * All cards are position:absolute, stacked at bottom.
   * They slide up into view one by one (translateY controlled by GSAP).
   */
  .training-cards-stage {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  /*
   * Each card: absolute, full width & height, top-anchored with offset.
   * Starts at translateY(100%) = hidden below viewport.
   * GSAP scrubs to translateY(0) = fully visible.
   * Higher z-index = later card = slides on top of previous.
   * Top offset creates deck-of-cards peek effect (earlier card tops visible).
   */
  .training-card {
    position: absolute;
    left: 3rem;
    right: 3rem;
    top: 0;
    height: 100%;
    background: #ffffff;
    border: 1px solid rgba(212,175,55,0.25);
    border-radius: 16px;
    overflow: hidden;
    transform: translateY(100%); /* initial state — hidden below */
    will-change: transform;
  }

  /* Each card offset slightly so deck tops peek out when stacked */
  .training-card[data-card-index="1"] { top: 12px; height: calc(100% - 12px); }
  .training-card[data-card-index="2"] { top: 24px; height: calc(100% - 24px); }
  .training-card[data-card-index="3"] { top: 36px; height: calc(100% - 36px); }

  .training-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 2.5rem 3rem;
    gap: 2rem;
    position: relative;
    z-index: 2;
    height: 100%;
  }

  .training-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #fff;
    background: #d4af37;
    border-radius: 4px;
    padding: 2px 6px;
    margin-right: 0.6rem;
    vertical-align: middle;
    line-height: 1.4;
    flex-shrink: 0;
  }

  .training-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .training-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .training-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 400;
    text-transform: uppercase;
    color: #0f4c75;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .training-badge {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.9;
  }

  .training-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #5a6c7d;
    max-width: 600px;
    margin: 0;
  }

  .training-milestone {
    text-align: right;
    flex-shrink: 0;
  }

  .milestone-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5a6c7d;
    margin-bottom: 0.25rem;
  }

  .milestone-val {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .milestone-tag {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
    margin-top: 0.25rem;
  }

  /* training-glow removed */

  @media (max-width: 1024px) {
    .training-header { padding: 4rem 2rem 1.5rem; }
    .training-card { left: 1.5rem; right: 1.5rem; }
    .training-inner {
      grid-template-columns: 1fr auto;
      padding: 2rem;
    }
    .training-milestone { text-align: left; }
  }

  @media (max-width: 640px) {
    .training-header { padding: 3.5rem 1.5rem 1.5rem; }
    .training-heading { font-size: clamp(2rem, 8vw, 3rem); }
    .training-inner { grid-template-columns: 1fr; padding: 1.5rem; }
    .training-milestone { text-align: left; }
    /* Smaller outer on mobile — still gives enough room for 4 cards */
    .training-scroll-outer { height: 400vh; }
  }

  /* ── Therapy ── */
  .therapy-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .therapy-text p {
    font-size: 1.15rem;
    color: #2c3e50;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .therapy-text h2 { min-height: 1.2em; }

  .therapy-image {
    width: 100%;
    height: clamp(160px, 22vh, 300px);
    background-image: url('/images/therapy.webp');
    background-size: cover;
    background-position: center;
    border-radius: 20px;
  }

  .workshop-image {
    width: 100%;
    height: clamp(140px, 18vh, 260px);
    background-image: url('/images/workshop.webp');
    background-size: cover;
    background-position: center;
    border-radius: 15px;
    margin-bottom: 1rem;
  }

  /* ── Testimonials ── */
  .testimonials-section { background: #ffffff; }

  .testimonial-container {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 0 80px;
  }

  .testimonials-section h3 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    color: #0f4c75;
    margin-bottom: 2rem;
    font-weight: 400;
    min-height: 1.2em;
  }

  /* hover aura removed — images use simple box-shadow only */

  /* ── Footer ── */
  footer { position: relative; z-index: 1; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .page-section { padding: 60px 0 40px; }

    .about-content {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .about-image { height: clamp(180px, 45vw, 280px); }

    .section-subtext { font-size: 1.05rem; }

    .therapy-content {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .therapy-image { height: 180px; }
    .workshop-image { height: 150px; }

    .testimonial-container { padding: 0 20px; }
    .testimonials-section h3 { font-size: 1.75rem; margin-bottom: 1.25rem; }

    .container { padding: 0 16px; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    * { transition-duration: 0.01ms !important; }
  }
</style>

<script>
  import { initAllAnimations } from '../lib/animations';

  function boot() {
    // Wait for GSAP + Lenis (both loaded via defer CDN tags)
    const MAX_WAIT = 4000;
    const start = Date.now();

    function tryInit() {
      const hasLenis = typeof (window as any).Lenis !== 'undefined';
      const hasGsap  = typeof (window as any).gsap  !== 'undefined';
      // Try to init even without GSAP — reveals + typewriter work without it
      const elapsed = Date.now() - start;

      if (hasLenis || elapsed > MAX_WAIT) {
        // Signal to CSS that JS animations are active
        document.body.classList.add('js-animations');
        initAllAnimations();
      } else {
        setTimeout(tryInit, 60);
      }
    }

    tryInit();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }
</script>
