---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import OfferingCards from '../components/OfferingCards.astro';
import Testimonials from '../components/Testimonials.astro';
import Modal from '../components/Modal.astro';
import Footer from '../components/Footer.astro';
---

<Layout>

  <!-- Fixed Navbar -->
  <Navbar />

  <!-- Hero + Video sections -->
  <Hero />

  <!-- ── Page Sections ── -->

  <!-- 3. About -->
  <section class="page-section about-section reveal-on-scroll" id="about">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <h2 data-typewriter="What makes QRH different?" data-typewriter-delay="200">What makes QRH different?</h2>
          <p class="reveal-on-scroll" data-reveal-delay="2">We guide you beyond what you thought was possible &#8212; whether through personal sessions or practitioner training.</p>
          <p class="reveal-on-scroll" data-reveal-delay="3">Healing here isn&#39;t about fixing what&#39;s broken; it&#39;s about discovering what&#39;s already extraordinary.</p>
        </div>
        <div class="about-image reveal-on-scroll" data-reveal-delay="2" role="img" aria-label="QRH healing environment"></div>
      </div>
    </div>
  </section>

  <!-- 4. Training Journey — sticky card stack -->
  <section class="page-section training-section" id="training">
    <div class="container">
      <div class="training-header reveal-on-scroll">
        <h2 data-typewriter="The Training Journey" data-typewriter-delay="200">The Training Journey</h2>
        <p class="section-subtext">Our 6-month program combines mentorship, immersive practice, and personal growth. An invitation to fully embody the work and confidently guide others.</p>
      </div>

      <!-- Sticky card stack: each card stacks as you scroll -->
      <div class="training-stack-outer">

        <div class="training-stack-card">
          <div class="training-card-number">01</div>
          <div class="training-card-icon-circle" aria-hidden="true">M</div>
          <h3>Mentorship</h3>
          <p>Weekly one-on-one and group sessions with experienced practitioners</p>
        </div>

        <div class="training-stack-card">
          <div class="training-card-number">02</div>
          <div class="training-card-icon-circle" aria-hidden="true">P</div>
          <h3>Practice</h3>
          <p>Hands-on practice and guided exploration in real-world settings</p>
        </div>

        <div class="training-stack-card">
          <div class="training-card-number">03</div>
          <div class="training-card-icon-circle" aria-hidden="true">S</div>
          <h3>Support</h3>
          <p>Marketing and client-building support to launch your practice</p>
        </div>

        <div class="training-stack-card">
          <div class="training-card-number">04</div>
          <div class="training-card-icon-circle" aria-hidden="true">C</div>
          <h3>Certification</h3>
          <p>Certificate of completion acknowledging your training and expertise</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 5. Therapy / Personal Healing -->
  <section class="page-section therapy-section reveal-on-scroll" id="therapy-section">
    <div class="container">
      <div class="therapy-content">
        <div class="therapy-text">
          <h2 data-typewriter="Personal Healing Sessions" data-typewriter-delay="200">Personal Healing Sessions</h2>
          <p class="reveal-on-scroll" data-reveal-delay="2">Individual sessions that take you to the root of your psyche and beyond. These are not about temporary relief &#8212; they&#39;re about transformation.</p>
          <p class="reveal-on-scroll" data-reveal-delay="3">Experience a unique approach to healing that awakens what&#39;s already extraordinary within you.</p>
        </div>
        <div class="therapy-images reveal-on-scroll" data-reveal-delay="2">
          <div class="workshop-image" role="img" aria-label="Workshop environment"></div>
          <div class="therapy-image" role="img" aria-label="Therapy session environment"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Testimonials -->
  <section class="page-section testimonials-section reveal-on-scroll">
    <div class="testimonial-container">
      <h3 data-typewriter="What Our Community Says" data-typewriter-delay="200">What Our Community Says</h3>
      <Testimonials />
    </div>
  </section>

  <!-- 7. Your Pathways -->
  <section class="page-section offerings-section reveal-on-scroll" id="offerings">
    <div class="container">
      <h2 data-typewriter="Your Pathways" data-typewriter-delay="200">Your Pathways</h2>
      <p class="section-subtext reveal-on-scroll" data-reveal-delay="2">You&#39;ve seen the work. Now choose your path &#8212; a personal healing session or the full practitioner training journey.</p>
      <OfferingCards />
    </div>
  </section>

  <!-- Footer -->
  <Footer />

  <!-- Global booking modal -->
  <Modal />

</Layout>

<style>
  /* ── Base resets for this page ── */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    font-family: 'Lato', sans-serif;
    line-height: 1.6;
    color: #2c3e50;
    overflow-x: clip;
    width: 100%;
  }
  body { background: #ffffff; }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Page sections ── */
  .page-section {
    position: relative;
    width: 100%;
    background: #ffffff;
    padding: 80px 0 60px;
  }

  /* ── Shared heading + subtext ── */
  .page-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: #0f4c75;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 1rem;
    min-height: 1.2em; /* prevent layout shift during typewriter */
  }

  .section-subtext {
    font-size: 1.15rem;
    color: #5a6c7d;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 700px;
  }

  /* ── About ── */
  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-text p {
    font-size: 1.15rem;
    color: #2c3e50;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .about-image {
    width: 100%;
    height: clamp(220px, 38vh, 420px);
    background-image: url('/images/about-image.webp');
    background-size: cover;
    background-position: center;
    border-radius: 20px;
    box-shadow: 0 25px 50px rgba(0,0,0,0.1);
    filter: drop-shadow(0 0 25px rgba(212,175,55,0.4));
  }

  /* ── Offerings ── */
  .offerings-section h2 { text-align: center; }
  .offerings-section .section-subtext {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Training section ── */
  .training-section { padding-bottom: 0; }
  .training-section h2 { text-align: center; min-height: 1.2em; }
  .training-header { text-align: center; margin-bottom: 2rem; }
  .training-header .section-subtext {
    margin: 0 auto 2rem;
  }

  /* Give the stack section enough height to show all 4 cards stacking */
  .training-stack-outer {
    max-width: 700px;
    margin: 0 auto;
    /* Each card is ~220px; 4 cards × 80px offset = 320px + last card full height */
    padding-bottom: 60px;
  }

  /* ── Therapy ── */
  .therapy-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .therapy-text p {
    font-size: 1.15rem;
    color: #2c3e50;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .therapy-text h2 { min-height: 1.2em; }

  .therapy-image {
    width: 100%;
    height: clamp(160px, 22vh, 300px);
    background-image: url('/images/therapy.webp');
    background-size: cover;
    background-position: center;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    filter: drop-shadow(0 0 20px rgba(212,175,55,0.35));
  }

  .workshop-image {
    width: 100%;
    height: clamp(140px, 18vh, 260px);
    background-image: url('/images/workshop.webp');
    background-size: cover;
    background-position: center;
    border-radius: 15px;
    margin-bottom: 1rem;
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    filter: drop-shadow(0 0 15px rgba(212,175,55,0.3));
  }

  /* ── Testimonials ── */
  .testimonials-section { background: #ffffff; }

  .testimonial-container {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 0 80px;
  }

  .testimonials-section h3 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    color: #0f4c75;
    margin-bottom: 2rem;
    font-weight: 400;
    min-height: 1.2em;
  }

  /* ── Hover aura on images ── */
  .about-image,
  .therapy-image,
  .workshop-image {
    transition: filter 0.4s ease;
  }
  .about-image:hover { filter: drop-shadow(0 0 35px rgba(212,175,55,0.7)); }
  .therapy-image:hover,
  .workshop-image:hover { filter: drop-shadow(0 0 30px rgba(212,175,55,0.6)); }

  /* ── Footer ── */
  footer { position: relative; z-index: 1; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .page-section { padding: 60px 0 40px; }

    .about-content {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .about-image { height: clamp(180px, 45vw, 280px); }

    .section-subtext { font-size: 1.05rem; }

    .training-stack-outer { max-width: 100%; }

    .therapy-content {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .therapy-image { height: 180px; }
    .workshop-image { height: 150px; }

    .testimonial-container { padding: 0 20px; }
    .testimonials-section h3 { font-size: 1.75rem; margin-bottom: 1.25rem; }

    .container { padding: 0 16px; }
  }

  @media (max-width: 480px) {
    .training-stack-outer { padding: 0 4px 40px; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    * { transition-duration: 0.01ms !important; }
  }
</style>

<script>
  import { initAllAnimations } from '../lib/animations';

  function boot() {
    // Wait for GSAP + Lenis (both loaded via defer CDN tags)
    const MAX_WAIT = 4000;
    const start = Date.now();

    function tryInit() {
      const hasLenis = typeof (window as any).Lenis !== 'undefined';
      const hasGsap  = typeof (window as any).gsap  !== 'undefined';
      // Try to init even without GSAP — reveals + typewriter work without it
      const elapsed = Date.now() - start;

      if (hasLenis || elapsed > MAX_WAIT) {
        // Signal to CSS that JS animations are active
        document.body.classList.add('js-animations');
        initAllAnimations();
      } else {
        setTimeout(tryInit, 60);
      }
    }

    tryInit();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }
</script>
