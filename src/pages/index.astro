---
import QrhhtNavbar from '../components/QrhhtNavbar.tsx';
import QrhhtFooter from '../components/QrhhtFooter.tsx';
import QrhhtHero from '../components/QrhhtHero.tsx';
import QrhhtOfferingCards from '../components/QrhhtOfferingCards.tsx';
import QrhhtCTAButtons from '../components/QrhhtCTAButtons.tsx';
import QrhhtTestimonials from '../components/QrhhtTestimonials.tsx';
import QrhhtModal from '../components/QrhhtModal.tsx';
import { QrhhtLenis } from '../components/QrhhtLenis.tsx';
import { QrhhtHeroScroll } from '../components/QrhhtHeroScroll.tsx';
import '../styles/global.css';

const pageTitle = "QRHHT - Dive deep. Rise higher. Live more.";
const pageDescription = "Healing and training that awaken what's extraordinary within you.";
const pageURL = "https://qrhht-landing.vercel.app/";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={pageURL} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content="/images/og-banner.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content="/images/og-banner.jpg" />
  <link rel="canonical" href={pageURL} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/images/lighthouse-icon-180.png" />

  <!-- Resource hints: preconnect to external domains -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://www.youtube.com" />
  <link rel="dns-prefetch" href="https://link.msgsndr.com" />

  <!-- Preload hero image (LCP) — WebP with JPG fallback -->
  <link rel="preload" as="image" href="/images/hero-bg.webp" fetchpriority="high"
    imagesrcset="/images/hero-bg-800.webp 800w, /images/hero-bg-1200.webp 1200w, /images/hero-bg.webp 1920w"
    imagesizes="100vw" />

  <!-- Google Fonts: load asynchronously to avoid render-blocking -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;600&family=Lato:wght@300;400;600&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;600&family=Lato:wght@300;400;600&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;600&family=Lato:wght@300;400;600&display=swap" rel="stylesheet" /></noscript>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Lato', sans-serif; line-height: 1.6; color: #2c3e50; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

    /* ── Hero (image background) ── */
    .hero {
      position: relative;
      height: 100vh;
      width: 100%;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      background: #ffffff;
    }
    /* Hero background image placeholder (LCP image is added via <img> tag) */
    .hero-bg-image {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      z-index: 0;
      overflow: hidden;
      pointer-events: none;
    }
    /* Gold shimmer accent at top */
    .hero-gold-accent {
      position: absolute;
      top: 0; left: 0; width: 100%;
      height: 3px;
      background: linear-gradient(
        to right,
        transparent 0%,
        rgba(212, 175, 55, 0.6) 30%,
        rgba(212, 175, 55, 1) 50%,
        rgba(212, 175, 55, 0.6) 70%,
        transparent 100%
      );
      z-index: 60;
      pointer-events: none;
    }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes heroFloat {
      0%, 100% { transform: translateY(0) translateZ(0); }
      50% { transform: translateY(-8px) translateZ(15px); }
    }
    /* Hero LCP image visible immediately (no fade animation) */
    .hero-content {
      position: relative;
      z-index: 3;
      max-width: 800px;
      padding: 80px 20px 0;
      transform-style: preserve-3d;
      animation: heroFloat 7s ease-in-out infinite;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem;
      font-weight: 300;
      color: #ffffff;
      margin-bottom: 1.5rem;
      letter-spacing: 1px;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }
    .hero .subtext {
      font-size: 1.4rem;
      color: #f0f0f0;
      margin-bottom: 3rem;
      line-height: 1.7;
      text-shadow: 1px 1px 3px rgba(0,0,0,0.5);
    }
    .hero-buttons {
      display: flex;
      gap: 32px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .cta-button {
      display: inline-block;
      padding: 15px 35px;
      font-size: 1.1rem;
      text-decoration: none;
      border-radius: 30px;
      transition: all 0.3s ease;
      font-weight: 600;
      letter-spacing: 0.5px;
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }
    .cta-primary { background: #d4af37; color: white; box-shadow: 0 4px 15px rgba(212,175,55,0.3); }
    .cta-secondary { background: #0f4c75; color: white; box-shadow: 0 4px 15px rgba(15,76,117,0.3); }
    .cta-button:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.2); }
    .cta-primary:hover { background: #f4c842; color: white; }
    .cta-secondary:hover { background: #1a5d8a; color: white; }

    /* ── Video Section ── */
    .video-section {
      background: #0a1a2e;
      min-height: 100vh;
      padding: 0;
    }
    .video-section::before,
    .video-section::after {
      display: none;
    }
    #video-wrapper {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      z-index: 0;
      overflow: hidden;
      pointer-events: none;
      padding: 0;
      box-sizing: border-box;
      background: #0a1a2e;
    }
    #video-container {
      position: absolute;
      border: none;
    }
    #video-unmute-btn {
      position: absolute;
      bottom: 30px; right: 30px;
      z-index: 3;
      background: rgba(255,255,255,0.9);
      border: none;
      border-radius: 50%;
      width: 50px; height: 50px;
      font-size: 1.5rem;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }
    #video-unmute-btn:hover { transform: scale(1.1); background: white; box-shadow: 0 6px 20px rgba(0,0,0,0.2); }

    /* ── About ── */
    .about { background: #ffffff; }
    .about-content { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .about h2 { font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #0f4c75; margin-bottom: 2rem; font-weight: 400; }
    .about p { font-size: 1.3rem; color: #2c3e50; line-height: 1.8; margin-bottom: 1.5rem; }
    .about-image { width: 100%; height: 450px; background-image: url('/images/about-image.webp'); background-size: cover; background-position: center; border-radius: 20px; box-shadow: 0 25px 50px rgba(0,0,0,0.1); }

    /* ── Offerings ── */
    .offerings { background: #ffffff; }
    .offerings h2 { font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #0f4c75; text-align: center; margin-bottom: 1rem; font-weight: 400; }
    .offerings-subtext { text-align: center; font-size: 1.3rem; color: #5a6c7d; margin-bottom: 4rem; max-width: 700px; margin-left: auto; margin-right: auto; line-height: 1.7; }
    .offerings-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; }
    .offering-card { background: white; padding: 40px; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); transition: all 0.3s ease; border: 3px solid transparent; text-align: center; }
    .offering-card:hover { transform: translateY(-10px); box-shadow: 0 25px 50px rgba(0,0,0,0.15); border-color: #d4af37; }
    .offering-card h3 { font-family: 'Playfair Display', serif; font-size: 2rem; color: #0f4c75; margin-bottom: 1.5rem; font-weight: 400; }
    .offering-card p { font-size: 1.2rem; color: #5a6c7d; line-height: 1.7; margin-bottom: 2rem; }

    /* ── Training Journey ── */
    .training-journey { background: #ffffff; }
    .training-journey h2 { font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #0f4c75; text-align: center; margin-bottom: 2rem; font-weight: 400; }
    .training-hero-image { width: 100%; max-width: 700px; height: 700px; background-image: url('/images/training-hero.webp'); background-size: cover; background-position: center; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); margin: 2rem auto 3rem; }
    .training-text { text-align: center; max-width: 800px; margin: 0 auto 4rem; font-size: 1.3rem; color: #2c3e50; line-height: 1.8; }
    .training-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; margin-bottom: 4rem; }
    .training-card { background: white; padding: 35px; border-radius: 15px; text-align: center; box-shadow: 0 15px 30px rgba(0,0,0,0.1); transition: all 0.3s ease; border-top: 4px solid #d4af37; }
    .training-card:hover { transform: translateY(-8px); box-shadow: 0 25px 40px rgba(0,0,0,0.15); }
    .training-card-icon { width: 70px; height: 70px; background: #0f4c75; border-radius: 50%; margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.8rem; font-weight: 600; }
    .training-card h3 { font-family: 'Playfair Display', serif; color: #d4af37; margin-bottom: 1rem; font-size: 1.4rem; font-weight: 600; }
    .training-card p { color: #5a6c7d; line-height: 1.6; font-size: 1.1rem; }

    /* ── Therapy Section ── */
    .therapy-section { background: #ffffff; }
    .therapy-content { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .therapy-section h2 { font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #0f4c75; margin-bottom: 2rem; font-weight: 400; }
    .therapy-section p { font-size: 1.3rem; color: #2c3e50; line-height: 1.8; margin-bottom: 2rem; }
    .therapy-image { width: 100%; height: 600px; background-image: url('/images/therapy.webp'); background-size: cover; background-position: center; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    .workshop-image { width: 100%; height: 500px; background-image: url('/images/workshop.webp'); background-size: cover; background-position: center; border-radius: 15px; margin-bottom: 2rem; box-shadow: 0 15px 30px rgba(0,0,0,0.1); }

    /* ── Testimonials ── */
    .testimonial-carousel { background: #ffffff; }
    .testimonial-container { max-width: 1000px; margin: 0 auto; text-align: center; padding: 0 60px; }
    .testimonial-carousel h3 { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #0f4c75; margin-bottom: 3rem; font-weight: 400; }

    /* ── Closing CTA ── */
    .closing-cta { background: #0f4c75; color: white; text-align: center; }
    .closing-cta h2 { font-family: 'Playfair Display', serif; font-size: 2.8rem; margin-bottom: 2rem; font-weight: 400; color: #d4af37; }
    .closing-cta p { font-size: 1.3rem; max-width: 700px; margin: 0 auto 3rem; line-height: 1.8; color: #e8e8e8; }
    .closing-buttons { display: flex; gap: 30px; justify-content: center; flex-wrap: wrap; }

    /* ── Modal ── */
    .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.7); backdrop-filter: blur(5px); overflow-y: auto; }
    .modal-content { background-color: white; margin: 2% auto; padding: 20px; border-radius: 20px; width: 90%; max-width: 800px; height: 90vh; max-height: 90vh; overflow: hidden; position: relative; box-shadow: 0 25px 50px rgba(0,0,0,0.3); display: flex; flex-direction: column; }
    .modal-close { color: #aaa; float: right; font-size: 28px; font-weight: bold; cursor: pointer; position: absolute; right: 20px; top: 15px; }
    .modal-close:hover { color: #0f4c75; }

    /* ── Animations ── */
    .fade-in { transition: all 0.8s ease; }
    .fade-in.animate { opacity: 1; transform: translateY(0); }

    /* ── Hero content: always visible on load — no initial hidden state ── */
    .hero-content h1,
    .hero-content .subtext {
      opacity: 1;
    }
    /* Hero content needs top padding to sit below fixed navbar */
    .hero-content {
      padding-top: 100px !important;
    }

    /* ── Responsive (handled by global.css mobile media queries) ── */
    @media (max-width: 768px) {
      /* Legacy overrides kept minimal — global.css handles the bulk */
      .training-hero-image { height: 220px; }
    }
  </style>
</head>
<body>

  <!-- Lenis smooth scroll wrapper (React, client:load) -->
  <QrhhtLenis client:load>

    <!-- Fixed plasma background container — behind ALL sections, no clipping (reduced auras for perf) -->
    <div class="plasma-background" aria-hidden="true">
      <!-- 3 strategic auras: top-left, top-right, center -->
      <div class="plasma-aura sz-lg col-gold  plasma-zone-1 delay-1"></div>
      <div class="plasma-aura sz-md col-teal  plasma-zone-3 delay-2"></div>
      <div class="plasma-aura sz-md col-aurora plasma-zone-7 delay-3"></div>
    </div>

    <!-- LiquidCN Navbar (React) -->
    <QrhhtNavbar client:load />

    <!-- Gold accent line at very top (above navbar) -->
    <div class="hero-gold-accent"></div>

    <!-- Hero: Framer Motion scroll effect (scale + rotate + opacity) -->
    <!-- QrhhtHeroScroll creates a 200vh spacer + sticky motion wrapper -->
    <QrhhtHeroScroll client:load>
      <section class="hero" id="hero" style="position:relative;height:100vh;overflow:hidden;background:#ffffff;display:flex;align-items:center;justify-content:center;text-align:center;">
        <div class="hero-bg-image">
          <!-- Preload hero image for LCP -->
          <img src="/images/hero-bg-400.webp" alt="Quantum Root Healing" class="hero-img-lcp" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:20px;" loading="eager" fetchpriority="high" decoding="sync" />
        </div>
        <div class="hero-content">
          <h1>Dive deep. Rise higher. Live more.</h1>
          <p class="subtext">Healing and training that awaken what&#39;s extraordinary within you.</p>
          <QrhhtHero client:idle />
        </div>
      </section>
    </QrhhtHeroScroll>

    <!-- New Video Section (YouTube background) -->
    <section class="video-section stack-section" id="video-section" style="z-index: 20;">
      <div id="video-wrapper" style="position:absolute;top:0;left:0;width:100%;height:100%;z-index:0;overflow:hidden;">
        <div id="video-container"></div>
      </div>
      <button id="video-unmute-btn" aria-label="Toggle sound">&#128263;</button>
    </section>

    <!-- About -->
    <section class="about stack-section" id="about" style="z-index: 30;padding:120px 0;">
      <div class="container">
        <div class="about-content">
          <div class="fade-in">
            <h2>What makes QRHHT different?</h2>
            <p>We guide you beyond what you thought was possible &#8212; whether through personal sessions or practitioner training.</p>
            <p>Healing here isn&#39;t about fixing what&#39;s broken; it&#39;s about discovering what&#39;s already extraordinary.</p>
          </div>
          <div class="about-image aura-image fade-in"></div>
        </div>
      </div>
    </section>

    <!-- Offerings -->
    <section class="offerings stack-section" id="offerings" style="z-index: 40;padding:120px 0;">
      <div class="container">
        <h2 class="fade-in">Your Pathways</h2>
        <p class="offerings-subtext fade-in">Whether you&#39;re here for your own healing or to help others heal, QRHHT offers an experience that transforms.</p>
        <QrhhtOfferingCards client:visible />
      </div>
    </section>

    <!-- Training Journey -->
    <section class="training-journey stack-section-tall" style="z-index: 50;padding:120px 0;">
      <div class="container">
        <h2 class="fade-in">The Training Journey</h2>
        <div class="training-hero-image aura-image fade-in"></div>
        <p class="training-text fade-in">Our 6-month program combines mentorship, immersive practice, and personal growth. An invitation to fully embody the work and confidently guide others.</p>
        <div class="training-cards">
          <div class="training-card aura-effect fade-in">
            <div class="training-card-icon">M</div>
            <h3>Mentorship</h3>
            <p>Weekly one-on-one and group sessions with experienced practitioners</p>
          </div>
          <div class="training-card aura-effect fade-in">
            <div class="training-card-icon">P</div>
            <h3>Practice</h3>
            <p>Hands-on practice and guided exploration in real-world settings</p>
          </div>
          <div class="training-card aura-effect fade-in">
            <div class="training-card-icon">S</div>
            <h3>Support</h3>
            <p>Marketing and client-building support to launch your practice</p>
          </div>
          <div class="training-card aura-effect fade-in">
            <div class="training-card-icon">C</div>
            <h3>Certification</h3>
            <p>Certificate of completion acknowledging your training and expertise</p>
          </div>
        </div>
        <div style="text-align:center">
          <QrhhtCTAButtons client:visible showBooking={false} trainingLabel="Train With Me" />
        </div>
      </div>
    </section>

    <!-- Therapy Section -->
    <section class="therapy-section stack-section-tall" style="z-index: 60;padding:120px 0;">
      <div class="container">
        <div class="therapy-content">
          <div class="fade-in">
            <h2>Personal Healing Sessions</h2>
            <p>Individual sessions that take you to the root of your psyche and beyond. These are not about temporary relief &#8212; they&#39;re about transformation.</p>
            <p>Experience a unique approach to healing that awakens what&#39;s already extraordinary within you.</p>
            <div style="margin-top:1rem">
              <QrhhtCTAButtons client:visible showTraining={false} bookingLabel="Book A Session" />
            </div>
          </div>
          <div class="fade-in">
            <div class="workshop-image aura-image"></div>
            <div class="therapy-image aura-image"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials (Swiper) -->
    <section class="testimonial-carousel stack-section-tall" style="z-index: 70;padding:80px 0;">
      <div class="testimonial-container">
        <h3>What Our Community Says</h3>
        <QrhhtTestimonials client:visible />
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="closing-cta stack-section-tall" id="contact" style="z-index: 80;padding:120px 0;">
      <div class="container">
        <h2 class="fade-in">Start your journey today.</h2>
        <p class="fade-in">Whether you&#39;re here for yourself or for others, the path starts with one choice &#8212; to dive deeper and rise higher.</p>
        <div class="closing-buttons">
          <QrhhtCTAButtons client:visible closingStyle={true} />
        </div>
      </div>
    </section>

    <!-- Intersection observer for fade-in animations -->
    <script>
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('animate'); });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('.fade-in, .about-image').forEach(el => obs.observe(el));
    </script>

    <!-- YouTube IFrame API — lazy-loaded via IntersectionObserver -->
    <script>
      let videoPlayer: any = null;
      let videoMuted = true;
      let ytApiLoaded = false;

      const _videoWrapper = document.getElementById('video-wrapper') as HTMLElement;

      function sizeVideo() {
        const iframe = _videoWrapper?.querySelector('iframe') as HTMLIFrameElement | null;
        if (!iframe) return;
        const w = _videoWrapper.offsetWidth;
        const h = _videoWrapper.offsetHeight;
        let vidW: number, vidH: number;
        if (w / h > 16 / 9) { vidW = w; vidH = w * 9 / 16; }
        else { vidH = h; vidW = h * 16 / 9; }
        iframe.style.position = 'absolute';
        iframe.style.width = vidW + 'px';
        iframe.style.height = vidH + 'px';
        iframe.style.left = ((w - vidW) / 2) + 'px';
        iframe.style.top = ((h - vidH) / 2) + 'px';
        iframe.style.border = 'none';
      }

      if (_videoWrapper) {
        const _videoRo = new ResizeObserver(sizeVideo);
        _videoRo.observe(_videoWrapper);
        window.addEventListener('resize', sizeVideo, { passive: true });
      }

      function loadYouTube() {
        if (ytApiLoaded) return;
        ytApiLoaded = true;
        const tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        document.head.appendChild(tag);
      }

      (window as any).onYouTubeIframeAPIReady = function() {
        videoPlayer = new (window as any).YT.Player('video-container', {
          videoId: 'I2CYPa_CxoU',
          playerVars: {
            autoplay: 1, controls: 0, loop: 1, mute: 1,
            playlist: 'I2CYPa_CxoU', showinfo: 0, rel: 0,
            modestbranding: 1, iv_load_policy: 3, disablekb: 1, fs: 0, playsinline: 1
          },
          events: {
            onReady: function(e: any) { e.target.mute(); e.target.playVideo(); sizeVideo(); },
            onStateChange: function(e: any) {
              if (e.data === (window as any).YT.PlayerState.ENDED) e.target.playVideo();
            }
          }
        });
      };

      const videoSection = document.getElementById('video-section');
      if (videoSection) {
        const videoObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) { loadYouTube(); videoObserver.disconnect(); }
            });
          },
          { rootMargin: '200px' }
        );
        videoObserver.observe(videoSection);
      }

      document.getElementById('video-unmute-btn')?.addEventListener('click', function(this: HTMLButtonElement) {
        if (!videoPlayer) return;
        if (videoMuted) {
          videoPlayer.unMute(); videoPlayer.setVolume(80);
          this.textContent = '🔊'; videoMuted = false;
        } else {
          videoPlayer.mute(); this.textContent = '🔇'; videoMuted = true;
        }
      });
    </script>

    <!-- Anime.js entrance animations: defer until after page load to unblock LCP -->
    <script>
      import { initScrollAnimations } from '../lib/animations';
      function initAnimations() {
        initScrollAnimations();
      }
      if (document.readyState === 'complete') {
        initAnimations();
      } else {
        window.addEventListener('load', initAnimations, { once: true });
      }
    </script>

